# Newsroom Docker configuration
# Copy this file to .env and edit as needed.
# docker compose will pick it up automatically.

# ── Pipeline parameters ─────────────────────────────────────────────────────
NEWSROOM_TARGET=5
NEWSROOM_CYCLES=500
# Options: sleep_study | wave_study (leave empty for default uniform batching)
NEWSROOM_CHOREOGRAPHY=

# ── LLM provider ────────────────────────────────────────────────────────────
# "ollama"  — entrypoint waits for Ollama, pulls model, uses Ollama's /v1 API
# "openai"  — entrypoint skips Ollama, validates OPENAI_API_KEY, hits OpenAI API
LLM_PROVIDER=ollama

# ── Ollama settings (only used when LLM_PROVIDER=ollama) ────────────────────
OLLAMA_MODEL=gpt-oss:20b
# OLLAMA_BASE_URL=http://localhost:11434    # default; override if Ollama is elsewhere

# ── OpenAI-compatible client (always used by Python) ────────────────────────
# These three vars are read by shared.create_llm_client() regardless of provider.
# When LLM_PROVIDER=ollama the defaults below point to Ollama's /v1 endpoint.
# When LLM_PROVIDER=openai override them to point to the real OpenAI API.
#OPENAI_API_KEY=<your-openai-api-key>
#OPENAI_MODEL_ID=gpt-5.4
#OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL_ID=gpt-oss:120b

# ── Example: OpenAI mode ────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-4.1

# ── Board UI ─────────────────────────────────────────────────────────────────
UI_PORT=8080
