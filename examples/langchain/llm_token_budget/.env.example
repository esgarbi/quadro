# Example environment for the LLM token-budget demo.
# Copy this file to .env and tweak as needed.

# ── LLM provider (any OpenAI-compatible endpoint) ─────────────────────────
# Default is a local Qwen model served by SGLang/vLLM on the standard
# OpenAI-compat /v1 path. The API key is ignored by the raw inference
# server but the client still requires a non-empty string.
OPENAI_API_KEY=local
OPENAI_BASE_URL=http://localhost:30000/v1
OPENAI_MODEL_ID=gpt-oss-120b

# Swap for real OpenAI:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-4.1

# Swap for local Ollama:
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL_ID=llama3.2

# ── Sponsor budget knob ───────────────────────────────────────────────────
# The total LLM tokens the sponsor will authorise across the run. Flip this
# to tell the two-run story:
#   LLM_BUDGET=50000  -> queue empties first (Drain -> orderly wind-down)
#   LLM_BUDGET=500    -> budget trips first  (Stop)
LLM_BUDGET=5000
