{
  "version": "0.2.0",
  "configurations": [
    // ── Newsroom: Docker debug ──────────────────────────────────────────
    //
    // Attach to the newsroom container running under debugpy.
    //
    // Steps:
    //   1. cd examples/newsroom/docker
    //   2. docker compose -f docker-compose.debug.yml up --build
    //   3. Wait for "[debug-entrypoint] ... WAITING for debugger to attach ..."
    //   4. Select this config in the Run panel and press F5
    //
    // The container bind-mounts src/quadro and the example source, so
    // breakpoints and edits work without rebuilding the image.
    // Board UI is available at http://localhost:8080 while debugging.
    {
      "name": "Attach: Newsroom Docker",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/examples/newsroom",
          "remoteRoot": "/app/examples/newsroom"
        },
        {
          "localRoot": "${workspaceFolder}/src/quadro",
          "remoteRoot": "/app/src/quadro"
        }
      ],
      "justMyCode": false
    },

    // ── Newsroom: Local run (no Docker) ─────────────────────────────────
    //
    // Runs main_pipeline.py directly on the host with a single-article target.
    //
    // Prerequisites:
    //   - pip install -e ".[dev]" && pip install agent-framework pydantic python-dotenv
    //   - LLM server running (Ollama, sglang, OpenAI, etc.)
    //   - Set OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL_ID in your
    //     environment or in a .env file at the example directory.
    //
    // The env block below defaults to a local Ollama instance.
    // Override as needed for your setup.
    {
      "name": "Launch: Newsroom Local",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/examples/newsroom/main_pipeline.py",
      "args": ["--target", "1", "--cycles", "200"],
      "cwd": "${workspaceFolder}/examples/newsroom",
      "env": {
        "OPENAI_API_KEY": "ollama",
        "OPENAI_BASE_URL": "http://localhost:11434/v1",
        "OPENAI_MODEL_ID": "gpt-oss:20b"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },

    // ── Ordering System: Docker debug ───────────────────────────────────
    //
    // Attach to the ordering system container running under debugpy.
    //
    // Steps:
    //   1. cd examples/ordering/docker
    //   2. docker compose -f docker-compose.debug.yml up --build
    //   3. Wait for "[debug-entrypoint] ... WAITING for debugger to attach ..."
    //   4. Select this config in the Run panel and press F5
    //
    // The container bind-mounts src/quadro and the example source, so
    // breakpoints and edits work without rebuilding the image.
    // Board UI is available at http://localhost:8081 while debugging.
    {
      "name": "Attach: Ordering Docker",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5679
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/examples/ordering",
          "remoteRoot": "/app/examples/ordering"
        },
        {
          "localRoot": "${workspaceFolder}/src/quadro",
          "remoteRoot": "/app/src/quadro"
        }
      ],
      "justMyCode": false
    },

    // ── Ordering System: Local run (no Docker) ──────────────────────────
    //
    // Runs main_pipeline.py directly on the host with a single-order target.
    //
    // Prerequisites:
    //   - pip install -e ".[dev]" && pip install agent-framework pydantic python-dotenv
    //   - LLM server running (Ollama, sglang, OpenAI, etc.)
    //   - Set OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL_ID in your
    //     environment or in a .env file at the example directory.
    //
    // The env block below defaults to a local Ollama instance.
    // Override as needed for your setup.
    {
      "name": "Launch: Ordering Local",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/examples/ordering/main_pipeline.py",
      "args": ["--target", "1", "--cycles", "200"],
      "cwd": "${workspaceFolder}/examples/ordering",
      "env": {
        "OPENAI_API_KEY": "ollama",
        "OPENAI_BASE_URL": "http://localhost:11434/v1",
        "OPENAI_MODEL_ID": "gpt-oss:20b"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
